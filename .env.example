# PostgreSQL
POSTGRES_USER=ppa
POSTGRES_PASSWORD=ppa_secret
POSTGRES_DB=ppa_db

# Database URLs
DATABASE_URL=postgresql+asyncpg://ppa:ppa_secret@db:5432/ppa_db
SYNC_DATABASE_URL=postgresql+psycopg2://ppa:ppa_secret@db:5432/ppa_db

# Redis
REDIS_URL=redis://redis:6379/0

# Application
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80,https://localhost,https://localhost:5173

# Frontend
VITE_API_BASE_URL=https://localhost/api

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
